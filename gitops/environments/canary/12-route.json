{
  "apiVersion": "route.openshift.io/v1",
  "kind": "Route",
  "metadata": {
    "name": "apollo-console-canary",
    "namespace": "apollo-canary",
    "labels": {
      "app": "apollo-console-rollout",
      "app.kubernetes.io/name": "apollo-console",
      "app.kubernetes.io/part-of": "apollo-agent-rollout"
    },
    "annotations": {
      "argocd.argoproj.io/sync-wave": "1",
      "haproxy.router.openshift.io/balance": "random",
      "haproxy.router.openshift.io/disable_cookies": "true"
    }
  },
  "spec": {
    "port": {
      "targetPort": "http"
    },
    "tls": {
      "termination": "edge",
      "insecureEdgeTerminationPolicy": "Redirect"
    },
    "to": {
      "kind": "Service",
      "name": "apollo-console-stable",
      "weight": 100
    },
    "alternateBackends": [
      {
        "kind": "Service",
        "name": "apollo-console-candidate",
        "weight": 0
      }
    ],
    "wildcardPolicy": "None"
  }
}
