{
  "apiVersion": "v1",
  "kind": "Service",
  "metadata": {
    "name": "apollo-console-stable",
    "namespace": "apollo-canary",
    "labels": {
      "app": "apollo-console-rollout",
      "app.kubernetes.io/name": "apollo-console",
      "app.kubernetes.io/part-of": "apollo-agent-rollout",
      "apollo.redhat.com/track": "stable"
    },
    "annotations": {
      "argocd.argoproj.io/sync-wave": "0"
    }
  },
  "spec": {
    "internalTrafficPolicy": "Cluster",
    "ports": [
      {
        "name": "http",
        "port": 8080,
        "protocol": "TCP",
        "targetPort": "http"
      }
    ],
    "selector": {
      "app": "apollo-console-rollout"
    },
    "sessionAffinity": "None",
    "type": "ClusterIP"
  }
}
