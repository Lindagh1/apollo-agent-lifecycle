{
  "apiVersion": "monitoring.coreos.com/v1",
  "kind": "ServiceMonitor",
  "metadata": {
    "name": "apollo-console-rollout",
    "namespace": "apollo-canary",
    "labels": {
      "app": "apollo-console-rollout",
      "app.kubernetes.io/name": "apollo-console",
      "app.kubernetes.io/part-of": "apollo-agent-rollout"
    },
    "annotations": {
      "argocd.argoproj.io/sync-wave": "1"
    }
  },
  "spec": {
    "selector": {
      "matchLabels": {
        "app.kubernetes.io/part-of": "apollo-agent-rollout"
      }
    },
    "namespaceSelector": {
      "matchNames": [
        "apollo-canary"
      ]
    },
    "targetLabels": [
      "apollo.redhat.com/track"
    ],
    "endpoints": [
      {
        "path": "/metrics",
        "interval": "15s",
        "scrapeTimeout": "10s",
        "scheme": "http"
      }
    ]
  }
}
