{
  "apiVersion": "argoproj.io/v1alpha1",
  "kind": "Rollout",
  "metadata": {
    "name": "apollo-console-rollout",
    "namespace": "apollo-canary",
    "labels": {
      "app": "apollo-console-rollout",
      "app.kubernetes.io/name": "apollo-console",
      "app.kubernetes.io/part-of": "apollo-agent-rollout"
    },
    "annotations": {
      "argocd.argoproj.io/sync-wave": "2"
    }
  },
  "spec": {
    "replicas": 2,
    "revisionHistoryLimit": 3,
    "progressDeadlineSeconds": 600,
    "selector": {
      "matchLabels": {
        "app": "apollo-console-rollout"
      }
    },
    "strategy": {
      "canary": {
        "stableService": "apollo-console-stable",
        "canaryService": "apollo-console-candidate",
        "maxSurge": 1,
        "maxUnavailable": 0,
        "trafficRouting": {
          "plugins": {
            "argoproj-labs/openshift": {
              "routes": [
                "apollo-console-canary"
              ]
            }
          }
        },
        "steps": [
          {
            "setWeight": 10
          },
          {
            "analysis": {
              "templates": [
                {
                  "templateName": "apollo-candidate-business-check"
                }
              ]
            }
          },
          {
            "pause": {}
          },
          {
            "setWeight": 50
          },
          {
            "analysis": {
              "templates": [
                {
                  "templateName": "apollo-candidate-business-check"
                }
              ]
            }
          },
          {
            "pause": {}
          },
          {
            "setWeight": 100
          }
        ]
      }
    },
    "template": {
      "metadata": {
        "labels": {
          "app": "apollo-console-rollout",
          "app.kubernetes.io/name": "apollo-console",
          "app.kubernetes.io/part-of": "apollo-agent-rollout"
        },
        "annotations": {
          "apollo.redhat.com/runtime-release": "stable-v1",
          "apollo.redhat.com/rollout-stage": "baseline"
        }
      },
      "spec": {
        "automountServiceAccountToken": false,
        "containers": [
          {
            "env": [
              {
                "name": "BOOKING_MCP_URL",
                "value": "http://booking-mcp.apollo-dev.svc.cluster.local:8080/mcp"
              },
              {
                "name": "DISRUPTION_MCP_URL",
                "value": "http://disruption-mcp.apollo-dev.svc.cluster.local:8080/mcp"
              },
              {
                "name": "POLICY_MCP_URL",
                "value": "http://policy-mcp.apollo-dev.svc.cluster.local:8080/mcp"
              },
              {
                "name": "CASE_MANAGEMENT_MCP_URL",
                "value": "http://case-management-mcp.apollo-dev.svc.cluster.local:8080/mcp"
              },
              {
                "name": "MODEL_BASE_URL",
                "value": "http://llama-32-3b-instruct-predictor.my-first-model.svc.cluster.local:8080"
              },
              {
                "name": "MODEL_ID",
                "value": "llama-32-3b-instruct"
              },
              {
                "name": "OTEL_TRACES_SAMPLER",
                "value": "always_on"
              },
              {
                "name": "OTEL_EXPORTER_OTLP_ENDPOINT",
                "value": "http://apollo-otel-collector.apollo-tracing.svc.cluster.local:4318/v1/traces"
              },
              {
                "name": "OTEL_DEPLOYMENT_ENVIRONMENT",
                "value": "apollo-canary"
              },
              {
                "name": "OTEL_SERVICE_NAME",
                "value": "apollo-console-rollout"
              },
              {
                "name": "OTEL_PYTHON_FASTAPI_EXCLUDED_URLS",
                "value": "/api/health,/metrics"
              },
              {
                "name": "APOLLO_RELEASE",
                "value": "stable-v1"
              },
              {
                "name": "APOLLO_RELEASE_CHANNEL",
                "value": "stable-v1"
              }
            ],
            "image": "image-registry.openshift-image-registry.svc:5000/apollo-dev/apollo-console@sha256:8fe9a0d78fe786b01f951b7c1ddec6295ba001906b357e8e7eb6fc710c285144",
            "imagePullPolicy": "IfNotPresent",
            "livenessProbe": {
              "failureThreshold": 3,
              "httpGet": {
                "path": "/api/health",
                "port": "http",
                "scheme": "HTTP"
              },
              "initialDelaySeconds": 15,
              "periodSeconds": 10,
              "successThreshold": 1,
              "timeoutSeconds": 3
            },
            "name": "apollo-console",
            "ports": [
              {
                "containerPort": 8080,
                "name": "http",
                "protocol": "TCP"
              }
            ],
            "readinessProbe": {
              "failureThreshold": 6,
              "httpGet": {
                "path": "/api/health",
                "port": "http",
                "scheme": "HTTP"
              },
              "initialDelaySeconds": 5,
              "periodSeconds": 5,
              "successThreshold": 1,
              "timeoutSeconds": 3
            },
            "resources": {
              "limits": {
                "cpu": "500m",
                "memory": "512Mi"
              },
              "requests": {
                "cpu": "100m",
                "memory": "128Mi"
              }
            },
            "securityContext": {
              "allowPrivilegeEscalation": false,
              "capabilities": {
                "drop": [
                  "ALL"
                ]
              },
              "runAsNonRoot": true,
              "seccompProfile": {
                "type": "RuntimeDefault"
              }
            },
            "terminationMessagePath": "/dev/termination-log",
            "terminationMessagePolicy": "File"
          }
        ],
        "dnsPolicy": "ClusterFirst",
        "restartPolicy": "Always",
        "schedulerName": "default-scheduler",
        "securityContext": {},
        "terminationGracePeriodSeconds": 30
      }
    }
  }
}
