{
  "apiVersion": "v1",
  "kind": "Service",
  "metadata": {
    "name": "apollo-console-stable",
    "namespace": "apollo-canary",
    "labels": {
      "app": "apollo-console-stable",
      "app.kubernetes.io/name": "apollo-console",
      "app.kubernetes.io/instance": "stable-v1",
      "app.kubernetes.io/part-of": "apollo-agent-canary",
      "apollo.redhat.com/release": "stable-v1",
      "release": "stable-v1"
    },
    "annotations": {
      "argocd.argoproj.io/sync-wave": "1",
      "argocd.argoproj.io/tracking-id": "apollo-staging:/Service:apollo-staging/apollo-console-candidate"
    }
  },
  "spec": {
    "internalTrafficPolicy": "Cluster",
    "ports": [
      {
        "name": "http",
        "port": 8080,
        "protocol": "TCP",
        "targetPort": "http"
      }
    ],
    "selector": {
      "app": "apollo-console-stable",
      "release": "stable-v1"
    },
    "sessionAffinity": "None",
    "type": "ClusterIP"
  }
}
