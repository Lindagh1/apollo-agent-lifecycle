      "gridPos": {
        "x": 12,
        "y": 3,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(apollo_model_request_duration_seconds_bucket[5m])))",
          "instant": true,
          "range": false,
          "refId": "A"
