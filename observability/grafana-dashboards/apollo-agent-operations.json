    {
      "id": 6,
      "type": "bargauge",
      "title": "Evaluation checks \u2014 last hour",
      "description": "Each row is a release check. A green bar means the check passed.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 9
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (check, status) (increase(apollo_evaluation_checks_total{suite=\"health-emergency-regression\",status=\"passed\"}[1h]))",
          "instant": true,
          "range": false,
          "refId": "A",
          "legendFormat": "{{check}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
